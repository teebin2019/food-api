# ── App ──
APP_ENV=development
SECRET_KEY=your-secret-key-here

# ── Database ──
DATABASE_URL=sqlite:///./food.db
# PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/fooddb

# ── Upload ──
UPLOAD_DIR=uploads

# ── CORS ──
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
